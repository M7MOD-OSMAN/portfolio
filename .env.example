# Copy to .env.local and fill in. Never commit real values.

# Resend API key for the contact form: https://resend.com/api-keys
RESEND_API_KEY=

# Sender for contact-form email. `onboarding@resend.dev` works without domain
# verification but only delivers to the Resend account owner's address.
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"

# Site URL: set once a custom domain is live. On Vercel this is
# auto-detected from VERCEL_PROJECT_PRODUCTION_URL if left unset.
NEXT_PUBLIC_SITE_URL=
