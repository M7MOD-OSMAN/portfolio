# Copy to .env.local and fill in. Never commit real values.

# Resend API key for the contact form: https://resend.com/api-keys
RESEND_API_KEY=

# Sender for contact-form email. `onboarding@resend.dev` works without domain
# verification but only delivers to the Resend account owner's address.
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"

# Site URL: set once a custom domain is live. On Vercel this is
# auto-detected from VERCEL_PROJECT_PRODUCTION_URL if left unset.
NEXT_PUBLIC_SITE_URL=

# --- Sanity CMS (projects, experience, skills) ---
# Leave the project id empty to render the bundled content in src/content
# instead. Find it at https://sanity.io/manage after creating a project.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Shared secret for the /api/revalidate webhook. Generate any random string
# and paste the same value into Sanity under API > Webhooks.
SANITY_REVALIDATE_SECRET=

# Write token used only by `npm run sanity:seed`, never at runtime. Create one
# with Editor permissions at https://sanity.io/manage > API > Tokens.
SANITY_API_WRITE_TOKEN=
